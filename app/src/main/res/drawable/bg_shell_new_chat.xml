<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/sidebar_pressed" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/sidebar_chip" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="@color/stroke_soft" />
        </shape>
    </item>
</selector>
