<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp"
    android:layout_height="180dp"
    android:layout_columnWeight="1"
    android:background="@drawable/bg_skill_card"
    android:orientation="vertical"
    android:padding="28px">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="60px"
            android:layout_height="60px"
            android:src="@mipmap/icon_skill"
            />

        <TextView
            android:id="@+id/tvSkillTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="canvas-design"
            android:textColor="#1F1F1F"
            android:textSize="28px"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivRemove"
            android:layout_width="32px"
            android:layout_height="32px"
            android:src="@mipmap/icon_remove"
            />
    </LinearLayout>

    <TextView
        android:id="@+id/tvSkillContent"
        android:layout_width="match_parent"
        android:layout_height="65px"
        android:maxHeight="65px"
        android:ellipsize="end"
        android:maxLines="2"
        android:layout_marginStart="75px"
        android:text="crate beautiful visual art png and .pdf documents..."
        android:textColor="#666666"
        android:textSize="23px" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:background="#ECECEC" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvSkillTag"
            android:layout_width="wrap_content"
            android:layout_height="48px"
            android:gravity="center"
            android:background="@drawable/bg_skill_tag"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="@string/setting_builtin_skill"
            android:textColor="#000000"
            android:textSize="24px" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageView
            android:id="@+id/skillSwitch"
            android:layout_width="48px"
            android:layout_height="28px"
            android:src="@mipmap/switch_off" />
    </LinearLayout>
</LinearLayout>