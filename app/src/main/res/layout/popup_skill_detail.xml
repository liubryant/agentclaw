<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/skillDetailOverlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:id="@+id/skillDetailDialog"
        android:layout_width="960px"
        android:layout_height="780px"
        android:layout_gravity="center"
        android:background="@drawable/bg_setting_dialog"
        android:orientation="vertical"
        android:paddingHorizontal="48px"
        android:paddingVertical="40px">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivSkillIcon"
                android:layout_width="96px"
                android:layout_height="96px"
                android:src="@mipmap/icon_skill"
                android:textColor="#222222"
                android:textSize="32px"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="28px"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvSkillDetailTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="canvas-design"
                    android:textColor="#000000"
                    android:textSize="40px"
                    />

                <TextView
                    android:id="@+id/tvSkillDetailTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4px"
                    android:text="@string/setting_builtin_skill"
                    android:textColor="#000000"
                    android:textSize="22px" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnSkillDetailRemove"
                android:layout_width="240px"
                android:layout_height="80px"
                android:background="@drawable/bg_skill_detail_remove_button"
                android:clickable="true"
                android:gravity="center"
                android:focusable="true"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="@string/setting_remove"
                android:textColor="#FF6C6C"
                android:textSize="24px" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvSkillDetailDescription"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:gravity="top|start"
            android:text="这里是技能详细介绍内容"
            android:textColor="#555555"
            android:textSize="24px" />

        <TextView
            android:id="@+id/tvSkillDetailStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            android:text="当前状态：已开启"
            android:textColor="#666666"
            android:textSize="24px" />
    </LinearLayout>

</FrameLayout>