<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_surface"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView android:id="@+id/packageName" style="@style/Widget.INMOClaw.CardTitle" android:layout_width="match_parent" android:layout_height="wrap_content" />
    <TextView android:id="@+id/packageDescription" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textColor="@color/text_secondary" />
    <TextView android:id="@+id/packageStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:textColor="@color/text_secondary" />
    <Button android:id="@+id/packageActionButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" />
</LinearLayout>


