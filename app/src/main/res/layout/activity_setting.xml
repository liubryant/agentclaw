<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A000000">

    <LinearLayout
        android:id="@+id/settingDialogContainer"
        android:layout_width="1400px"
        android:layout_height="900px"
        android:background="@drawable/bg_setting_left"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="20px">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="332px"
                android:layout_height="match_parent"
                android:background="@drawable/bg_setting_left"
                android:orientation="vertical"
                android:padding="34px">

                <LinearLayout
                    android:layout_width="332px"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="332px"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_title"
                        android:textColor="#222222"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/menuUsage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="20px"
                    android:paddingHorizontal="48px"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="40px"
                        android:layout_height="40px"
                        android:src="@mipmap/list_data"
                        android:tint="#444444" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="@string/setting_menu_usage_stats"
                        android:textColor="#222222"
                        android:textSize="28px" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/menuSkill"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="60px"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingVertical="20px"
                    android:paddingHorizontal="48px">

                    <ImageView
                        android:layout_width="40px"
                        android:layout_height="40px"
                        android:src="@mipmap/list_skill"
                        android:tint="#444444" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="@string/setting_menu_skill_management"
                        android:textColor="#222222"
                        android:textSize="28px" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/menuAbout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12px"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingVertical="20px"
                    android:paddingHorizontal="48px">

                    <ImageView
                        android:layout_width="40px"
                        android:layout_height="40px"
                        android:src="@mipmap/list_about"
                        android:tint="#444444" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:text="@string/setting_menu_about_us"
                        android:textColor="#222222"
                        android:textSize="28px" />
                </LinearLayout>
            </LinearLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_setting_right"
                android:padding="48px">

                <LinearLayout
                    android:id="@+id/pageSkill"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_skill_page_title"
                        android:textColor="#222222"
                        android:textSize="32px"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/setting_skill_page_subtitle"
                        android:textColor="#8A8A8A"
                        android:textSize="24px" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="68px"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/bg_search"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp">

                            <ImageView
                                android:layout_width="40px"
                                android:layout_height="40px"
                                android:src="@mipmap/icon_search" />

                            <EditText
                                android:id="@+id/etSkillSearch"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@android:color/transparent"
                                android:hint="@string/setting_skill_search_hint"
                                android:imeOptions="actionSearch"
                                android:inputType="text"
                                android:textSize="24px"
                                android:paddingStart="10dp"
                                android:singleLine="true"
                                android:textColor="#333333"
                                android:textColorHint="#999999" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/btnAddSkill"
                            android:layout_width="110dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="10dp"
                            android:background="@drawable/bg_add_skill"
                            android:gravity="center"
                            android:text="@string/setting_add_skill"
                            android:textColor="#000000"
                            android:textSize="24px" />
                    </LinearLayout>

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="12dp"
                        android:layout_weight="1"
                        android:fillViewport="true"
                        android:overScrollMode="never"
                        android:scrollbars="vertical">

                        <LinearLayout
                            android:id="@+id/skillContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </ScrollView>
                </LinearLayout>

                <View
                    android:id="@+id/pageUsage"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/pageAbout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/setting_menu_about_us"
                        android:textColor="#222222"
                        android:textSize="32px"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="200px"
                            android:layout_height="140px"
                            android:adjustViewBounds="true"
                            android:src="@mipmap/about_icon" />

                        <ImageView
                            android:layout_width="262px"
                            android:layout_height="80px"
                            android:layout_marginTop="8px"
                            android:adjustViewBounds="true"
                            android:src="@mipmap/about_title" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="10px"
                        android:paddingHorizontal="72px"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingTop="12dp">

                        <LinearLayout
                            android:id="@+id/rowCurrentVersion"
                            android:layout_width="match_parent"
                            android:layout_height="80px"
                            android:layout_marginHorizontal="4dp"
                            android:background="@drawable/bg_about_item"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="28px">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/setting_current_version"
                                android:textColor="#222222"
                                android:textSize="24px" />

                            <TextView
                                android:id="@+id/tvVersion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8px"
                                android:text="V-"
                                android:textColor="#999999"
                                android:textSize="20px" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_weight="1" />

                            <ImageView
                                android:layout_width="24px"
                                android:layout_height="24px"
                                android:layout_marginStart="12px"
                                android:visibility="gone"
                                android:src="@mipmap/arrow_right"
                                android:tint="#B1B1B1" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/rowUserAgreement"
                            android:layout_width="match_parent"
                            android:layout_height="80px"
                            android:layout_marginHorizontal="4dp"
                            android:layout_marginTop="20px"
                            android:background="@drawable/bg_about_item"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="28px">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/setting_user_agreement"
                                android:textColor="#222222"
                                android:textSize="24px" />

                            <ImageView
                                android:layout_width="40px"
                                android:layout_height="40px"
                                android:src="@mipmap/arrow_right"
                                android:tint="#B1B1B1" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/rowPrivacyPolicy"
                            android:layout_width="match_parent"
                            android:layout_height="80px"
                            android:layout_marginHorizontal="4dp"
                            android:layout_marginTop="20px"
                            android:background="@drawable/bg_about_item"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="28px">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/setting_privacy_policy"
                                android:textColor="#222222"
                                android:textSize="24px" />

                            <ImageView
                                android:layout_width="40px"
                                android:layout_height="40px"
                                android:src="@mipmap/arrow_right"
                                android:tint="#B1B1B1" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/rowOpenSourceLicense"
                            android:visibility="gone"
                            android:layout_width="match_parent"
                            android:layout_height="80px"
                            android:layout_marginHorizontal="4dp"
                            android:layout_marginTop="20px"
                            android:background="@drawable/bg_about_item"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="28px">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/setting_open_source_license"
                                android:textColor="#222222"
                                android:textSize="24px" />

                            <ImageView
                                android:layout_width="40px"
                                android:layout_height="40px"
                                android:src="@mipmap/arrow_right"
                                android:tint="#B1B1B1" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>