<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/ideas_heading"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/filterAll"
                style="@style/Widget.INMOClaw.FilterChip"
                android:text="@string/ideas_filter_all" />

            <RadioButton
                android:id="@+id/filterWork"
                style="@style/Widget.INMOClaw.FilterChip"
                android:layout_marginStart="8dp"
                android:text="@string/ideas_filter_work" />

            <RadioButton
                android:id="@+id/filterAutomation"
                style="@style/Widget.INMOClaw.FilterChip"
                android:layout_marginStart="8dp"
                android:text="@string/ideas_filter_automation" />

            <RadioButton
                android:id="@+id/filterLife"
                style="@style/Widget.INMOClaw.FilterChip"
                android:layout_marginStart="8dp"
                android:text="@string/ideas_filter_life" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/ideaRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/emptyView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/ideas_empty"
        android:textColor="@color/text_secondary"
        android:visibility="gone" />
</LinearLayout>
