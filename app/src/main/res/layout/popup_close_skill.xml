<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/removeConfirmOverlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:id="@+id/removeConfirmDialog"
        android:layout_width="720px"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_setting_dialog"
        android:orientation="vertical"
        android:paddingHorizontal="42px"
        android:paddingTop="36px"
        android:paddingBottom="28px">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setting_confirm_close_skill"
            android:textColor="#222222"
            android:textSize="32px"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRemoveConfirmMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/setting_close_skill_warning_suffix"
            android:textColor="#7A000000"
            android:textSize="24px" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnCancelRemove"
                android:layout_width="250px"
                android:layout_height="76px"
                android:background="@drawable/bg_about_item"
                android:gravity="center"
                android:text="@string/setting_cancel"
                android:textColor="#555555"
                android:textSize="28px" />

            <TextView
                android:id="@+id/btnConfirmRemove"
                android:layout_width="250px"
                android:layout_height="76px"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_btn_select"
                android:gravity="center"
                android:text="@string/setting_close"
                android:textColor="@color/white"
                android:textSize="28px" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>