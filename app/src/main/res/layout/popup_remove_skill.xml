<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="148px"
    android:layout_height="72px"
    android:background="@drawable/bg_remove_popup"
    android:orientation="vertical"
    android:paddingHorizontal="32px"
    android:paddingVertical="22px">

    <LinearLayout
        android:id="@+id/optionRemove"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?android:attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        >

        <ImageView
            android:id="@+id/ivOptionRemoveIcon"
            android:layout_width="28px"
            android:layout_height="28px"
            android:src="@mipmap/icon_delete" />

        <TextView
            android:id="@+id/tvOptionRemove"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginStart="8px"
            android:text="@string/setting_remove"
            android:textColor="#FF6C6C"
            android:textSize="24px"
            />
    </LinearLayout>

</LinearLayout>