<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/summaryPrimary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/summarySecondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/summaryTertiary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <Button
            android:id="@+id/addTaskButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/schedule_add_task" />
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/filterAll"
                style="@style/Widget.INMOClaw.FilterChip"
                android:text="@string/schedule_filter_all" />

            <RadioButton
                android:id="@+id/filterRunning"
                style="@style/Widget.INMOClaw.FilterChip"
                android:layout_marginStart="8dp"
                android:text="@string/schedule_filter_running" />

            <RadioButton
                android:id="@+id/filterPaused"
                style="@style/Widget.INMOClaw.FilterChip"
                android:layout_marginStart="8dp"
                android:text="@string/schedule_filter_paused" />

            <RadioButton
                android:id="@+id/filterCompleted"
                style="@style/Widget.INMOClaw.FilterChip"
                android:layout_marginStart="8dp"
                android:text="@string/schedule_filter_completed" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/taskRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/emptyView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/schedule_empty"
        android:textColor="@color/text_secondary"
        android:visibility="gone" />
</LinearLayout>
